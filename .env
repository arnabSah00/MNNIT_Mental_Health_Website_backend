# ---------------------------------------------------------------------------
# Copy this file to ".env" (same folder) and fill in your real values.
# ".env" is where the backend reads its PostgreSQL connection info from.
# ---------------------------------------------------------------------------

# Server
PORT=5000
NODE_ENV=development

# --- PostgreSQL connection ---
# Option A: individual fields (used by src/config/db.js by default)
PGHOST=localhost
PGPORT=5432
PGDATABASE=mhc
PGUSER=postgres
PGPASSWORD=Arnab@2001

# Option B: single connection string (uncomment to use instead of the fields above)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mhc_db

# Set to true only if your Postgres provider requires SSL (e.g. most cloud DBs: Render, Railway, Supabase, RDS)
PG_SSL=false

# --- Auth ---
JWT_SECRET=Motilal
JWT_EXPIRES_IN=1d

# --- CORS ---
# The URL your frontend runs on (Vite dev server default shown below)
FRONTEND_ORIGIN=http://localhost:5173
